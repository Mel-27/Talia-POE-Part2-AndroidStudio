                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-R 650" android:textColor="@color/error_red" android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Yesterday" android:textColor="@color/muted_text" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
