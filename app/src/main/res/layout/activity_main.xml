<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/cream">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:scrollbars="none" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!-- ── Cream Top Bar — Logo + App Name ────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@color/cream" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/budgetbee" android:scaleType="fitCenter" android:contentDescription="Budget Bee Logo"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="Budget Bee" android:textColor="@color/black_deep" android:textSize="22sp" android:fontFamily="@font/fredoka_one"/>
            </LinearLayout>
            <!-- ── Dark Header ─────────────────────────────── -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/dashboard_header_bg" android:paddingStart="22dp" android:paddingEnd="22dp" android:paddingTop="20dp" android:paddingBottom="22dp">
                <LinearLayout android:id="@+id/greetingRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                    <!-- Greeting text -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Good morning," android:textColor="#99FFF9EC" android:textSize="13sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:id="@+id/tvUserName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gia 🐝" android:textColor="@color/cream" android:textSize="22sp" android:fontFamily="@font/fredoka_one"/>
                    </LinearLayout>
                    <!-- Bell -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnReminders"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#33FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🔔"
                            android:gravity="center"
                            android:textSize="20sp"/>

                    </androidx.cardview.widget.CardView>
                    <!-- Avatar -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">
                        <TextView
                            android:id="@+id/tvAvatarInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="G"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <androidx.cardview.widget.CardView android:id="@+id/balanceCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/greetingRow" app:cardCornerRadius="22dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/honey">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp">
                        <LinearLayout android:id="@+id/balanceLeft" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_toStartOf="@+id/streakCard" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MONTHLY BUDGET LEFT" android:textColor="#99291A00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/tvBalanceAmount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 3,240" android:textColor="@color/black_deep" android:textSize="40sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:id="@+id/tvBalanceSub" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="of R 5,000 budget · Mar 2026" android:textColor="#88291A00" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:id="@+id/streakCard" android:layout_width="64dp" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" app:cardCornerRadius="16dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/black_deep">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥7" android:textColor="@color/honey" android:textSize="22sp" android:fontFamily="@font/fredoka_one" android:gravity="center"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="day\nstreak" android:textColor="#99FFF9EC" android:textSize="9sp" android:fontFamily="sans-serif-medium" android:textStyle="bold" android:gravity="center" android:letterSpacing="0.05"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </RelativeLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="18dp" android:paddingEnd="18dp" android:paddingTop="18dp" android:paddingBottom="100dp">
                <!-- Quick Cards -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="18dp">
                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardCornerRadius="18dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💸" android:textSize="26sp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPENT" android:textColor="@color/muted_text" android:textSize="10sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/tvSpentAmount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R1,760" android:textColor="@color/black_deep" android:textSize="22sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↑ 12% vs last month" android:textColor="@color/error_red" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" app:cardCornerRadius="18dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏦" android:textSize="26sp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SAVED" android:textColor="@color/muted_text" android:textSize="10sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/tvSavedAmount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 840" android:textColor="@color/black_deep" android:textSize="22sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↓ on track ✓" android:textColor="@color/success_green" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <!-- Budget Progress -->
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="18dp" app:cardCornerRadius="18dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="March Budget" android:textColor="@color/black_deep" android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:id="@+id/tvBudgetBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="On Track" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:background="@drawable/badge_green_bg" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        </LinearLayout>
                        <ProgressBar android:id="@+id/progressBudget" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="10dp" android:progress="35" android:progressDrawable="@drawable/progress_green" android:indeterminate="false"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="R1,760 spent" android:textColor="@color/muted_text" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R5,000 goal" android:textColor="@color/black_deep" android:textSize="12sp" android:fontFamily="sans-serif-medium" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <!-- ── Upcoming Payments Timeline ────────────── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Upcoming Payments"
                                android:textColor="@color/black_deep"
                                android:textSize="17sp"
                                android:fontFamily="@font/fredoka_one" />
                            <TextView
                                android:id="@+id/tvSeeAllReminders"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:minHeight="48dp"
                                android:minWidth="48dp"
                                android:gravity="center"
                                android:text="See All →"
                                android:textColor="@color/honey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="12dp"/>
                        </LinearLayout>

                        <!-- Timeline row: Rent -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:layout_width="24dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">
                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/cal_dot_honey"
                                    android:layout_marginTop="6dp" />
                                <View
                                    android:layout_width="2dp"
                                    android:layout_height="50dp"
                                    android:background="@color/input_stroke" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:orientation="vertical"
                                android:layout_marginBottom="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1 Apr 2026"
                                    android:textColor="@color/muted_text"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="4dp">
                                    <androidx.cardview.widget.CardView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        app:cardCornerRadius="10dp"
                                        app:cardElevation="0dp"
                                        app:cardBackgroundColor="#FFF3D0">
                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:text="🏠"
                                            android:gravity="center"
                                            android:textSize="16sp" />
                                    </androidx.cardview.widget.CardView>
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="8dp"
                                        android:text="Rent"
                                        android:textColor="@color/black_deep"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:fontFamily="sans-serif-medium" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="R 5,000"
                                        android:textColor="@color/black_deep"
                                        android:textSize="14sp"
                                        android:fontFamily="@font/fredoka_one" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Timeline row: Netflix (last — no line) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:layout_width="24dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">
                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/cal_dot_honey"
                                    android:layout_marginTop="6dp" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="15 Apr 2026"
                                    android:textColor="@color/muted_text"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="4dp">
                                    <androidx.cardview.widget.CardView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        app:cardCornerRadius="10dp"
                                        app:cardElevation="0dp"
                                        app:cardBackgroundColor="#FFE4E4">
                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:text="📺"
                                            android:gravity="center"
                                            android:textSize="16sp" />
                                    </androidx.cardview.widget.CardView>
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="8dp"
                                        android:text="Netflix"
                                        android:textColor="@color/black_deep"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:fontFamily="sans-serif-medium" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="R 199"
                                        android:textColor="@color/black_deep"
                                        android:textSize="14sp"
                                        android:fontFamily="@font/fredoka_one" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Top Spending -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Top Spending" android:textColor="@color/black_deep" android:textSize="18sp" android:fontFamily="@font/fredoka_one"/>
                    <TextView android:id="@+id/tvSeeAllCats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="See All →" android:textColor="@color/honey_dark" android:textSize="12sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:clickable="true" android:focusable="true" android:padding="4dp"/>
                </LinearLayout>
                <!-- Groceries -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF3D0">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🛒" android:gravity="center" android:textSize="20sp"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Groceries" android:textColor="@color/black_deep" android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 640 / R 1,000" android:textColor="@color/muted_text" android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="5dp" android:progress="64" android:progressDrawable="@drawable/progress_honey" android:indeterminate="false"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 640" android:textColor="@color/black_deep" android:textSize="16sp" android:fontFamily="@font/fredoka_one" android:layout_marginStart="10dp"/>
                </LinearLayout>
                <!-- Entertainment -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="18dp">
                    <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFE4E4">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🎬" android:gravity="center" android:textSize="20sp"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entertainment" android:textColor="@color/black_deep" android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 480 / R 500 · Over limit!" android:textColor="@color/error_red" android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="5dp" android:progress="96" android:progressDrawable="@drawable/progress_red" android:indeterminate="false"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R 480" android:textColor="@color/error_red" android:textSize="16sp" android:fontFamily="@font/fredoka_one" android:layout_marginStart="10dp"/>
                </LinearLayout>
                <!-- Recent Transactions -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Recent" android:textColor="@color/black_deep" android:textSize="18sp" android:fontFamily="@font/fredoka_one"/>
                    <TextView android:id="@+id/tvSeeAllTx" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="See All →" android:textColor="@color/honey_dark" android:textSize="12sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:clickable="true" android:focusable="true" android:padding="4dp"/>
                </LinearLayout>
                <!-- Mugg & Bean -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="12dp" android:paddingBottom="12dp">
                    <androidx.cardview.widget.CardView android:layout_width="42dp" android:layout_height="42dp" app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF3D0">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="☕" android:gravity="center" android:textSize="22sp"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mugg &amp; Bean" android:textColor="@color/black_deep" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food &amp; Drink · Today" android:textColor="@color/muted_text" android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-R 85" android:textColor="@color/error_red" android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today" android:textColor="@color/muted_text" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/input_stroke"/>
                <!-- Engen -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="12dp" android:paddingBottom="12dp">
                    <androidx.cardview.widget.CardView android:layout_width="42dp" android:layout_height="42dp" app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#E4F7FF">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="⛽" android:gravity="center" android:textSize="22sp"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Engen Fuel" android:textColor="@color/black_deep" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
