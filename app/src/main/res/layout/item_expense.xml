<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Category icon block -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCategoryIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF3D0">
            <TextView
                android:id="@+id/tvCategoryIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📝"
                android:gravity="center"
                android:textSize="22sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Description + category with time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExpenseDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/black_deep"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvExpenseCategoryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category · Time"
                android:textColor="@color/muted_text"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Amount + date label + receipt link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvExpenseAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-R 0"
                android:textColor="@color/error_red"
                android:textSize="17sp"
                android:fontFamily="@font/fredoka_one"/>

            <TextView
                android:id="@+id/tvExpenseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@color/muted_text"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_gravity="end"/>

            <!-- Only visible when receipt photo exists -->
            <TextView
                android:id="@+id/tvReceiptLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📎 RECEIPT"
                android:textColor="@color/honey_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="3dp"
                android:layout_gravity="end"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>