<?xml version="1.0" encoding="utf-8"?>

<!-- CoordinatorLayout used as the root layout to support scrolling behaviour
     ref: https://developer.android.com/reference/androidx/coordinatorlayout/widget/CoordinatorLayout -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <!-- ScrollView so the whole screen scrolls if content overflows
         ref: https://developer.android.com/reference/android/widget/ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- page header with back button and title
                 ref: https://developer.android.com/guide/topics/ui/layout/linear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="18dp"
                android:background="@color/cream">

                <!-- back button using a TextView with a click listener wired in the activity
                     ref: https://developer.android.com/reference/android/view/View#setOnClickListener(android.view.View.OnClickListener) -->
                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/honey"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Expense"
                    android:textColor="@color/black_deep"
                    android:textSize="32sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- body section with expense form fields and action buttons
                 ref: https://developer.android.com/guide/topics/ui/layout/linear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="40dp">

                <!-- CardView wrapping the expense detail input fields
                     ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EXPENSE DETAILS"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <!-- TextInputLayout with OutlinedBox style for the description field
                             ref: https://developer.android.com/reference/com/google/android/material/textfield/TextInputLayout -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDescription"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Description"
                                android:inputType="text"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- TextInputLayout for the amount field with a prefix of R for Rands
                             ref: https://developer.android.com/reference/com/google/android/material/textfield/TextInputLayout -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAmount"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:prefixText="R "
                            app:prefixTextColor="@color/black_deep"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAmount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0.00"
                                android:inputType="numberDecimal"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- date field is non-editable, tapping opens MaterialDatePicker in the activity
                             ref: https://developer.android.com/reference/com/google/android/material/datepicker/MaterialDatePicker -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDate"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:endIconMode="custom"
                            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:endIconTint="@color/honey_dark"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Date"
                                android:focusable="false"
                                android:clickable="true"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- category dropdown using ExposedDropdownMenu style and AutoCompleteTextView
                             ref: https://developer.android.com/reference/com/google/android/material/textfield/TextInputLayout -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCategory"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <AutoCompleteTextView
                                android:id="@+id/actvCategory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:text="Category"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- CardView wrapping the receipt photo upload area
                     ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECEIPT PHOTO"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp" />

                        <!-- dashed upload area wired via photoUploadArea id in the activity
                             clicking this opens the image picker
                             ref: https://developer.android.com/training/data-storage/shared/photopicker -->
                        <LinearLayout
                            android:id="@+id/photoUploadArea"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/dashed_upload_bg"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🖼️"
                                android:textSize="36sp"
                                android:layout_marginBottom="10dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to upload receipt"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select a photo from your gallery"
                                android:textColor="@color/muted_text"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- cancel and save buttons side by side using layout_weight
                     ref: https://developer.android.com/reference/com/google/android/material/button/MaterialButton -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- cancel button uses OutlinedButton style and is wired via btnCancel id
                         ref: https://developer.android.com/guide/components/intents-filters -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:text="Cancel"
                        android:textColor="@color/muted_text"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="18dp" />

                    <!-- save button wired via btnSaveExpense id to insert the expense into Room DB
                         ref: https://developer.android.com/training/data-storage/room/accessing-data#insert -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveExpense"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Save Expense 🍯"
                        android:textColor="@color/black_deep"
                        android:textSize="15sp"
                        android:fontFamily="@font/fredoka_one"
                        app:backgroundTint="@color/honey"
                        app:cornerRadius="18dp"
                        app:elevation="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

