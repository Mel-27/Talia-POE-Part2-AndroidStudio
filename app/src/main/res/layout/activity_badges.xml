<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CREAM TOP BAR — Logo + App Name (matches dashboard) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- DARK HERO HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_header_bg"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="22dp"
                android:paddingBottom="22dp">

                <LinearLayout
                    android:id="@+id/heroTitleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hive Rewards"
                        android:textColor="@color/cream"
                        android:textSize="28sp"
                        android:fontFamily="@font/fredoka_one" />



                </LinearLayout>

                <!-- Honey Points balance card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/honeyPointsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/heroTitleRow"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/honey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HONEY POINTS"
                            android:textColor="#99291A00"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvHoneyPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200 🍯"
                            android:textColor="@color/black_deep"
                            android:textSize="42sp"
                            android:fontFamily="@font/fredoka_one"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 pts to Honey Collector"
                            android:textColor="#88291A00"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp" />

                        <!-- Progress row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Progress to next badge"
                                android:textColor="#AA291A00"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="200 / 250 pts"
                                android:textColor="#CC291A00"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressNextBadge"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:progress="80"
                            android:progressDrawable="@drawable/progress_dark"
                            android:indeterminate="false" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </RelativeLayout>

            <!-- BODY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Badges"
                    android:textColor="@color/black_deep"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="14dp" />

                <!-- Badge row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Badge 1: Worker Bee — EARNED -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✓ Earned" android:textColor="@color/success_green"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_gravity="end"
                                android:layout_marginBottom="6dp"/>
                            <ImageView android:layout_width="110dp" android:layout_height="110dp"
                                android:src="@drawable/worker_bee" android:scaleType="fitCenter"
                                android:layout_gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="100 pts" android:textColor="@color/honey_dark"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:gravity="center"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Badge 2: Honey Collector — LOCKED -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:alpha="0.45"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔒 Locked" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_gravity="end"
                                android:layout_marginBottom="6dp"/>
                            <ImageView android:layout_width="110dp" android:layout_height="110dp"
                                android:src="@drawable/honey_collector" android:scaleType="fitCenter"
                                android:layout_gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="250 pts" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:gravity="center"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Badge row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Badge 3: Honey Hoarder — LOCKED -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.45"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔒 Locked" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_gravity="end"
                                android:layout_marginBottom="6dp"/>
                            <ImageView android:layout_width="110dp" android:layout_height="110dp"
                                android:src="@drawable/honey_hoarder" android:scaleType="fitCenter"
                                android:layout_gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="500 pts" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:gravity="center"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Badge 4: Queen Bee — LOCKED -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:alpha="0.45"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔒 Locked" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:layout_gravity="end"
                                android:layout_marginBottom="6dp"/>
                            <ImageView android:layout_width="110dp" android:layout_height="110dp"
                                android:src="@drawable/queen_bee" android:scaleType="fitCenter"
                                android:layout_gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1,000 pts" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" android:gravity="center"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- HOW TO EARN POINTS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How to Earn Points"
                    android:textColor="@color/black_deep"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="18dp">

                        <!-- Row 1 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="14dp">
                            <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                                app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF3D0">
                                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:text="📝" android:gravity="center" android:textSize="20sp"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:text="Add an expense" android:textColor="@color/black_deep"
                                android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="+5 pts" android:textColor="@color/honey_dark"
                                android:textSize="14sp" android:fontFamily="@font/fredoka_one"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/input_stroke" android:layout_marginBottom="14dp"/>

                        <!-- Row 2 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="14dp">
                            <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                                app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#E8F5E9">
                                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:text="✅" android:gravity="center" android:textSize="20sp"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:text="Stay within daily budget" android:textColor="@color/black_deep"
                                android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="+10 pts" android:textColor="@color/honey_dark"
                                android:textSize="14sp" android:fontFamily="@font/fredoka_one"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/input_stroke" android:layout_marginBottom="14dp"/>

                        <!-- Row 3 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="14dp">
                            <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                                app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF3D0">
                                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:text="🔥" android:gravity="center" android:textSize="20sp"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:text="Log expenses 5 days in a row" android:textColor="@color/black_deep"
                                android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="+20 pts" android:textColor="@color/honey_dark"
                                android:textSize="14sp" android:fontFamily="@font/fredoka_one"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/input_stroke" android:layout_marginBottom="14dp"/>

                        <!-- Row 4 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                                app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#E8F5E9">
                                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:text="🎯" android:gravity="center" android:textSize="20sp"/>
                            </androidx.cardview.widget.CardView>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:text="Meet your savings goal" android:textColor="@color/black_deep"
                                android:textSize="13sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="+25 pts" android:textColor="@color/honey_dark"
                                android:textSize="14sp" android:fontFamily="@font/fredoka_one"/>
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:paddingBottom="8dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🏠" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navExpenses" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="📋" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Expenses" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <androidx.cardview.widget.CardView android:id="@+id/fabAddExpense"
                android:layout_width="54dp" android:layout_height="54dp" android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp" app:cardBackgroundColor="@color/honey"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="+" android:gravity="center" android:textColor="@color/black_deep"
                    android:textSize="30sp" android:fontFamily="sans-serif-black"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout android:id="@+id/navGoals" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🎯" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Goals" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navBadges" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFD454">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🏆" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Badges" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/honey_dark" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>