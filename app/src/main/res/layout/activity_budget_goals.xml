<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one" />
            </LinearLayout>

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dashboard_header_bg"
                android:padding="20dp">

                <TextView
                    android:text="Budget Goals"
                    android:textColor="@color/cream"
                    android:textSize="28sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="March 2026 · Update any limit below"
                    android:textColor="#99FFF9EC"
                    android:textSize="13sp"
                    android:layout_marginBottom="18dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Budget Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/honey">

                    <LinearLayout
                        android:padding="18dp"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="TOTAL MONTHLY BUDGET"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#99291A00"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvTotalBudget"
                            android:text="R 5,000"
                            android:textSize="36sp"
                            android:fontFamily="@font/fredoka_one"
                            android:textColor="@color/black_deep"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvBudgetSubtitle"
                            android:text="R 1,760 spent · R 3,240 remaining"
                            android:textSize="12sp"
                            android:textColor="#88291A00"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <ProgressBar
                            android:id="@+id/progressTotalBudget"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:progress="35"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFDF7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:padding="12dp"
                    android:background="#FFF8E1">

                    <!-- Groceries -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelGroceries"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barGroceries"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:minHeight="20dp"
                            android:background="#FFD180"/>
                    </LinearLayout>

                    <!-- Entertainment -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelEntertainment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barEntertainment"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:minHeight="20dp"
                            android:background="#EF9A9A"/>
                    </LinearLayout>

                    <!-- Transport -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelTransport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barTransport"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:minHeight="20dp"
                            android:background="#A5D6A7"/>
                    </LinearLayout>

                    <!-- Food -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelFood"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barFood"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:minHeight="20dp"
                            android:background="#FFAB91"/>
                    </LinearLayout>

                    <!-- Health -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelHealth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:textSize="10sp"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barHealth"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:minHeight="20dp"
                            android:background="#B0BEC5"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Monthly budget: R"
                            android:textSize="13sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <EditText
                            android:id="@+id/etMonthlyBudget"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:hint="5000"
                            android:inputType="numberDecimal"
                            android:layout_height="wrap_content"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUpdateMonthlyBudget"
                            android:text="Update"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>



    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📋" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="+"
            android:textSize="24sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🎯" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏆" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>