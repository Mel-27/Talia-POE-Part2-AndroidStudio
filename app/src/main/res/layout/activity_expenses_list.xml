<?xml version="1.0" encoding="utf-8"?>
<!--
    BUDGET BEE — Expenses Screen
    Changes in this version:
    • Cream top bar (logo + "Budget Bee") above dark header — matches all other screens
    • Dark header with title row: "Expenses" + subtitle left, "+ Category" honey pill right
    • Stats card (TOTAL | ITEMS | AVG/DAY) inside dark header
    • Filter chips: uniform 34dp height, 12sp, consistent paddingStart/End + marginEnd
    • Added "📅 Date Range" chip (4th chip)
    • Sort row: "Sort:" muted label + two 34dp CardView pills side-by-side
    • Custom date range row hidden by default (visibility=gone)
    • All RECEIPT TextViews are tappable (clickable + focusable + foreground ripple)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Cream Top Bar — Logo + App Name ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- ── Dark Page Header ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="22dp"
                android:background="@drawable/dashboard_header_bg">

                <!-- Title + subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expenses"
                    android:textColor="@color/cream"
                    android:textSize="28sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="4dp" />



                <!-- Stats card (honey) inside dark header -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/honey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalExpenses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R4,635"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ITEMS"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalItems"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AVG/DAY"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvAvgPerDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R165"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ════════════════════════════════════════════
                 BODY
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="100dp">

                <!-- ── Date Filter Chips — uniform 34dp height ──────── -->
                <!--
                    Kotlin chip switching pattern:
                    val chips = listOf(chipThisMonth, chipLast7, chip3Months)
                    chips.forEach { chip ->
                        chip.setOnClickListener {
                            chips.forEach { it.setBackgroundResource(R.drawable.tab_row_bg); it.setTextColor(...muted) }
                            chip.setBackgroundResource(R.drawable.tab_active_bg); chip.setTextColor(...black_deep)
                            // filter expense list by selected range
                        }
                    }
                -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Active chip -->
                        <TextView
                            android:id="@+id/chipThisMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="This Month"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_active_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/chipLast7"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="Last 7 Days"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip3Months"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="3 Months"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- ── Always-visible Date Range Row ─────────────────── -->
                <LinearLayout
                    android:id="@+id/dateRangeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/btn_start_date"
                        android:contentDescription="@string/cd_start_date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#8594;"
                        android:textColor="@color/muted_text"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:layout_weight="1"
                        android:text="&#128197; End date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                </LinearLayout>

                <!-- ── Add Category Banner — full-width outlined button ── -->
                <!-- Kotlin: btnAddCategory.setOnClickListener { startActivity(Intent(this, AddCategoryActivity::class.java)) } -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCategory"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:text="+ Add Expense Category"
                    android:textColor="@color/honey_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    app:strokeColor="@color/honey_dark"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp" />

                <!-- ── Sort Row — two pills, just above the expense list ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sort:"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginEnd="10dp" />

                    <!-- Newest First — active (honey) by default -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">
                        <TextView
                            android:id="@+id/tvSortDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="&#8595; Newest First"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                    <!-- Oldest First — inactive (white) by default -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortAsc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white">
                        <TextView
                            android:id="@+id/tvSortAsc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="&#8593; Oldest First"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- ── DATE SECTION: TODAY ─────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY"
                        android:textColor="@color/muted_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_stroke"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <!-- Expense 1: Woolworths -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <androidx.cardview.widget.CardView
                            android:layout_width="44dp" android:layout_height="44dp"
                            app:cardCornerRadius="14dp" app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFF3D0">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                android:text="&#128722;" android:gravity="center" android:textSize="22sp"/>
                        </androidx.cardview.widget.CardView>
                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Woolworths" android:textColor="@color/black_deep"
                                android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Groceries · 10:30 AM" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-R 450" android:textColor="@color/error_red"
                                android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Today" android:textColor="@color/muted_text"
                                android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:id="@+id/tvReceipt1"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="&#128206; RECEIPT"
                                android:textColor="@color/honey_dark" android:textSize="11sp"
                                android:textStyle="bold" android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="3dp" android:layout_gravity="end"
                                android:clickable="true" android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:padding="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Expense 2: McDonald's -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView
                            android:layout_width="44dp" android:layout_height="44dp"
                            app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF3D0">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                android:text="&#127828;" android:gravity="center" android:textSize="22sp"/>
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="McDonald&apos;s" android:textColor="@color/black_deep"
                                android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Dining Out · 1:15 PM" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-R 85" android:textColor="@color/error_red"
                                android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Today" android:textColor="@color/muted_text"
                                android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:id="@+id/tvReceipt2"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="&#128206; RECEIPT"
                                android:textColor="@color/honey_dark" android:textSize="11sp"
                                android:textStyle="bold" android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="3dp" android:layout_gravity="end"
                                android:clickable="true" android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:padding="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── DATE SECTION: YESTERDAY ──────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="YESTERDAY" android:textColor="@color/muted_text" android:textSize="11sp"
                        android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"
                        android:background="@color/input_stroke" android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Expense 3: Uber -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                            app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#E4F7FF">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                android:text="&#128663;" android:gravity="center" android:textSize="22sp"/>
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Uber" android:textColor="@color/black_deep"
                                android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Transport · 8:30 PM" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-R 65" android:textColor="@color/error_red"
                                android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Yesterday" android:textColor="@color/muted_text"
                                android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:id="@+id/tvReceipt3"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="&#128206; RECEIPT"
                                android:textColor="@color/honey_dark" android:textSize="11sp"
                                android:textStyle="bold" android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="3dp" android:layout_gravity="end"
                                android:clickable="true" android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:padding="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── DATE SECTION: FEB 28 ──────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FEB 28" android:textColor="@color/muted_text" android:textSize="11sp"
                        android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"
                        android:background="@color/input_stroke" android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Expense 4: Cinema -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                        <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                            app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#F0E6FF">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                                android:text="&#127916;" android:gravity="center" android:textSize="22sp"/>
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cinema" android:textColor="@color/black_deep"
                                android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Entertainment · 7:45 PM" android:textColor="@color/muted_text"
                                android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-R 220" android:textColor="@color/error_red"
                                android:textSize="17sp" android:fontFamily="@font/fredoka_one"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Feb 28" android:textColor="@color/muted_text"
                                android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
                            <TextView
                                android:id="@+id/tvReceipt4"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="&#128206; RECEIPT"
                                android:textColor="@color/honey_dark" android:textSize="11sp"
                                android:textStyle="bold" android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="3dp" android:layout_gravity="end"
                                android:clickable="true" android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:padding="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ════════════════════════════════════════════════════
         BOTTOM NAV — Expenses tab active
    ════════════════════════════════════════════════════ -->
    <LinearLayout
