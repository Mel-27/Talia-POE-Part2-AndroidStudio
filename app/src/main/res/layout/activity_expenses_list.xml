<?xml version="1.0" encoding="utf-8"?>
<!--
    Reference:
    Used for implementing RecyclerView and layout structure:
    GeeksforGeeks (2025). RecyclerView in Android with Example. [online] GeeksforGeeks. Available at:
    https://www.geeksforgeeks.org/android/android-recyclerview/.
    [Accessed 26 Apr. 2026]
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Bar with Logo + App Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- Dark Page Header  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="22dp"
                android:background="@drawable/dashboard_header_bg">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expenses"
                    android:textColor="@color/cream"
                    android:textSize="28sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="4dp" />

                <!-- Stats card (honey) inside dark header -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/honey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalExpenses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R4,635"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ITEMS"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalItems"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AVG/DAY"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvAvgPerDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R165"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- BODY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="100dp">

                <!-- Date Filter Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/chipThisMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="This Month"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_active_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/chipLast7"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="Last 7 Days"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip3Months"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="3 Months"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                </HorizontalScrollView>

                <!--  Always-visible Date Range Row -->
                <LinearLayout
                    android:id="@+id/dateRangeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="&#128197; Start date"
                        android:contentDescription="Select start date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#8594;"
                        android:textColor="@color/muted_text"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:layout_weight="1"
                        android:text="&#128197; End date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                </LinearLayout>

                <!-- Add Category Banner -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCategory"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:text="+ Add Expense Category"
                    android:textColor="@color/honey_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    app:strokeColor="@color/honey_dark"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp" />

                <!--  Sort Row  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sort:"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginEnd="10dp" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">
                        <TextView
                            android:id="@+id/tvSortDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="&#8595; Newest First"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortAsc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white">
                        <TextView
                            android:id="@+id/tvSortAsc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="&#8593; Oldest First"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- RecyclerView - replaces all hardcoded expense cards -->
                <!-- GeeksforGeeks (2025) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false" />

                <!-- Empty state - shown when no expenses exist for the selected period -->
                <LinearLayout
                    android:id="@+id/layoutEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="48dp"
                    android:paddingBottom="48dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍯"
                        android:textSize="48sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No expenses found"
                        android:textColor="@color/black_deep"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="12dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try a different date range"
                        android:textColor="@color/muted_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>