<?xml version="1.0" encoding="utf-8"?>

<!-- CoordinatorLayout used as the root layout to support scrolling behaviour
     ref: https://developer.android.com/reference/androidx/coordinatorlayout/widget/CoordinatorLayout -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <!-- ScrollView so the whole screen scrolls if content overflows
         ref: https://developer.android.com/reference/android/widget/ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        android:paddingBottom="40dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- dark header section with avatar, name and email
                 ref: https://developer.android.com/guide/topics/ui/layout/linear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dashboard_header_bg"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="28dp">

                <!-- back button using a TextView with a click listener wired in the activity
                     ref: https://developer.android.com/reference/android/view/View#setOnClickListener(android.view.View.OnClickListener) -->
                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/honey"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- CardView used to create the rounded avatar circle
                         ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="68dp"
                        android:layout_height="68dp"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">
                        <!-- avatar initial gets set dynamically from SharedPreferences in the activity -->
                        <TextView
                            android:id="@+id/tvAvatarLarge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="G"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <!-- name and email get populated from Room DB in the activity
                             ref: https://developer.android.com/training/data-storage/room -->
                        <TextView
                            android:id="@+id/tvAccountName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gia"
                            android:textColor="@color/cream"
                            android:textSize="22sp"
                            android:fontFamily="@font/fredoka_one" />

                        <TextView
                            android:id="@+id/tvAccountEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="gia@budgetbee.app"
                            android:textColor="#99FFF9EC"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />

                        <!-- member since pill using a CardView with a rounded corner radius
                             ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#33FFF9EC">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🐝 Member since Jan 2026"
                                android:textColor="@color/cream"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp" />
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- body section with profile form and account options
                 ref: https://developer.android.com/guide/topics/ui/layout/linear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="@color/black_deep"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="12dp" />

                <!-- CardView wrapping the profile form fields
                     ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FULL NAME"
                            android:textColor="@color/muted_text"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="6dp" />

                        <!-- TextInputLayout with OutlinedBox style for the name field
                             ref: https://developer.android.com/reference/com/google/android/material/textfield/TextInputLayout -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilName"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Gia"
                                android:inputType="textPersonName|textCapWords"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL ADDRESS"
                            android:textColor="@color/muted_text"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="6dp" />

                        <!-- TextInputLayout with OutlinedBox style for the email field
                             ref: https://developer.android.com/reference/com/google/android/material/textfield/TextInputLayout -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEmail"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="gia@budgetbee.app"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- save button using MaterialButton wired to the activity via btnSaveProfile id
                             ref: https://developer.android.com/reference/com/google/android/material/button/MaterialButton -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveProfile"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Save Changes"
                            android:textColor="@color/black_deep"
                            android:textSize="15sp"
                            android:fontFamily="@font/fredoka_one"
                            app:backgroundTint="@color/honey"
                            app:cornerRadius="14dp"
                            app:elevation="2dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textColor="@color/black_deep"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="12dp" />

                <!-- CardView wrapping sign out and delete account options
                     ref: https://developer.android.com/reference/androidx/cardview/widget/CardView -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <!-- theme toggle pill with light and dark options
                             ref: https://developer.android.com/guide/topics/ui/look-and-feel/darktheme -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="App Theme"
                                    android:textColor="@color/black_deep"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Light mode"
                                    android:textColor="@color/muted_text"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <androidx.cardview.widget.CardView
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                app:cardCornerRadius="50dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#F0F0F0">
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:padding="3dp">

                                    <!-- light mode button wired via btnLight id in the activity -->
                                    <androidx.cardview.widget.CardView
                                        android:id="@+id/btnLight"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        app:cardCornerRadius="50dp"
                                        app:cardElevation="2dp"
                                        app:cardBackgroundColor="@color/white">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="match_parent"
                                            android:text="☀ Light"
                                            android:gravity="center"
                                            android:textColor="@color/black_deep"
                                            android:textSize="11sp"
                                            android:textStyle="bold"
                                            android:fontFamily="sans-serif-medium"
                                            android:paddingStart="12dp"
                                            android:paddingEnd="12dp" />
                                    </androidx.cardview.widget.CardView>

                                    <!-- dark mode button wired via btnDark id in the activity -->
                                    <TextView
                                        android:id="@+id/btnDark"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:text="🌙 Dark"
                                        android:gravity="center"
                                        android:textColor="@color/muted_text"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp" />

                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/input_stroke"
                            android:layout_marginStart="14dp" android:layout_marginEnd="14dp"/>

                        <!-- sign out row wired via rowSignOut id in the activity
                             ref: https://developer.android.com/reference/android/view/View#setOnClickListener(android.view.View.OnClickListener) -->
                        <LinearLayout
                            android:id="@+id/rowSignOut"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Sign Out"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="@color/muted_text"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/input_stroke"
                            android:layout_marginStart="14dp" android:layout_marginEnd="14dp"/>

                        <!-- delete account row wired via rowDeleteAccount id in the activity
                             ref: https://developer.android.com/reference/android/view/View#setOnClickListener(android.view.View.OnClickListener) -->
                        <LinearLayout
                            android:id="@+id/rowDeleteAccount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Delete Account"
                                android:textColor="@color/error_red"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="@color/error_red"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

